TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Comma-separated list of Telegram chat IDs allowed to run bot commands
TELEGRAM_ALLOWED_CHAT_IDS=your_chat_id_here
# Secret key required in X-API-Key header for REST API calls. Leave empty to disable auth.
TRADE_SIGNALS_API_KEY=
# OpenRouter API key for /signalsplus LLM summaries
OPENROUTER_API_KEY=
