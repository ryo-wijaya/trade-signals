{
  "watchlist": ["AMZN", "BABA", "MSFT", "NVDA"],
  "interval_hours": 2,
  "priority_interval_minutes": 30,
  "indicators": {
    "ema": {
      "window": 200
    },
    "bollinger": {
      "window": 20,
      "std_dev": 2,
      "buffer_pct": 0.01
    },
    "rsi": {
      "window": 14,
      "ma_window": 14
    },
    "cmf": {
      "window": 20,
      "threshold": 0.05
    }
  },
  "data": {
    "history_period": "200d",
    "bar_interval": "1h",
    "rth_start": "09:30",
    "rth_end": "16:00",
    "resample": "2h",
    "fetch_retries": 3,
    "ticker_sleep_seconds": 0.5
  },
  "scheduler": {
    "exchange_timezone": "America/New_York",
    "rth_open_hour": 10,
    "rth_close_hour": 16,
    "minute_offset": 5,
    "valid_batch_intervals": [1, 2, 4],
    "valid_priority_intervals": [15, 30, 60]
  },
  "display": {
    "timezone": "Asia/Singapore",
    "timestamp_format": "%d %b %Y  %I:%M %p SGT"
  },
  "market": {
    "calendar": "NYSE"
  }
}
